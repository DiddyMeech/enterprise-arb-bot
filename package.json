{
  "name": "enterprise-arb-bot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:decision-engine": "npm run build -w @arb/trade-decision-engine",
    "build": "npm run build:decision-engine",
    "verify:executor:arb": "npm run build && node scripts/verify-executor-selectors.js arbitrum",
    "verify:executor:base": "npm run build && node scripts/verify-executor-selectors.js base",
    "smoke:arb:wallet": "npm run build && node scripts/known-good-route-smoke-test.js arbitrum wallet",
    "smoke:arb:flash": "npm run build && node scripts/known-good-route-smoke-test.js arbitrum flash",
    "smoke:base:wallet": "npm run build && node scripts/known-good-route-smoke-test.js base wallet",
    "smoke:base:flash": "npm run build && node scripts/known-good-route-smoke-test.js base flash",
    "smoke:arb:two-leg": "node scripts/two-leg-smoke-test.js arbitrum wallet",
    "smoke:base:two-leg": "node scripts/two-leg-smoke-test.js base wallet",
    "start:scanner": "node apps/scanner/index.js",
    "start:simulator": "npm run build && node apps/simulator/index.js",
    "start:executor": "npm run build && node apps/executor/index.js",
    "start:learner": "node apps/learner/index.js",
    "start:coordinator": "node apps/coordinator/index.js",
    "start:dashboard": "node apps/dashboard/index.js",
    "start:cex": "node apps/cex-dex-scanner/index.js",
    "start:spatial": "node apps/spatial-scanner/index.js",
    "start:overseer": "node apps/overseer/index.js",
    "deploy:base": "node scripts/deploy.js base",
    "deploy:arb": "node scripts/deploy.js arbitrum",
    "deploy:op": "node scripts/deploy.js op"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ethers": "5.7.2",
    "express": "^4.19.2",
    "https-proxy-agent": "^5.0.1",
    "pg": "^8.11.0",
    "pm2": "^5.3.1",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@aave/core-v3": "^1.19.3",
    "hardhat": "^2.22.15"
  }
}
