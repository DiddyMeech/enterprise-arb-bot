# ── RPC ──────────────────────────────────────────────────────────────────────
# Single premium RPC URL for Arbitrum (Alchemy / Infura recommended)
ARBITRUM_RPC_URL=

# ── CONTRACT ─────────────────────────────────────────────────────────────────
# Deployed ArbitrageExecutor address on Arbitrum
ARB_CONTRACT_ADDRESS=

# Wallet private key (never commit the real .env)
PRIVATE_KEY=

# ── TRADING MODE ─────────────────────────────────────────────────────────────
# Set to false to enable live execution
SAFE_MODE=true

# Chains to scan (comma separated, e.g. arbitrum,base)
ACTIVE_CHAINS=arbitrum

# ── STRATEGY ─────────────────────────────────────────────────────────────────
# Trade size used for quoting (USD)
TRADE_USD_HINT=250

# Minimum gross profit to consider an opportunity (USD)
MIN_GROSS_PROFIT_USD=1.5

# Minimum net profit after gas + fees (USD)
MIN_NET_PROFIT_USD=1.0

# Per-leg slippage tolerance (basis points, 30 = 0.30%)
SLIPPAGE_BPS=30

# ── GAS ──────────────────────────────────────────────────────────────────────
# Estimated gas units for a 2-leg arb
GAS_UNITS_APPROX=260000

# Max gas as a fraction of gross profit (0.5 = 50%)
MAX_GAS_TO_GROSS_RATIO=0.5

# ── TIMING ───────────────────────────────────────────────────────────────────
# How often to poll for opportunities (ms)
POLL_INTERVAL_MS=3000

# How many seconds until a quoted route expires
ROUTE_DEADLINE_SECONDS=45

# ── PRICE ────────────────────────────────────────────────────────────────────
# ETH price hint for gas cost estimates (USD)
ETH_PRICE_USD_HINT=2200
