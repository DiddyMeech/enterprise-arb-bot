AAVE_POOL_ADDRESSES_PROVIDER=0xa97684ead0e402dC232d5A977953DF7ECBaB3CDb

########################################
# EXECUTION MODE
########################################
FLASH_LOAN_ENABLED=true
SAFE_MODE=true

########################################
# STRATEGY SETTINGS
########################################
TRADE_USD_HINT=25
DRY_RUN_USD=25
MIN_GROSS_PROFIT_USD=0.10
MIN_NET_PROFIT_USD=0.02
SLIPPAGE_BPS=50
ENABLE_UNIV3=true

########################################
# GAS SETTINGS — Polygon is much cheaper
########################################
GAS_UNITS_APPROX=260000
MAX_GAS_TO_GROSS_RATIO=0.50
# Update MATIC price as needed
ETH_PRICE_USD_HINT=0.9

########################################
# TIMING
########################################
POLL_INTERVAL_MS=3000
ROUTE_DEADLINE_SECONDS=45

########################################
# PRIMARY RPC (AUTO-SET BY ROTATOR)
########################################
ARB_RPC_EXEC=
ARB_RPC_SCAN=
ARB_RPC_CONF=

########################################
# RPC POOLS — Polygon
########################################
