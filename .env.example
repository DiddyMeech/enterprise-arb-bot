# ── RPC POOLS ────────────────────────────────────────────────────────────────
# Comma-separated premium RPC URLs (used by RpcManager for rotation + failover)
ARBITRUM_RPC_URLS=https://arb-premium-1.example,https://arb-premium-2.example
ARBITRUM_WSS_URLS=wss://arb-wss-1.example,wss://arb-wss-2.example

# Single-URL fallback (used by makeProvider() in scanner/simulator)
ARBITRUM_RPC_URL=

# RPC rotation health check interval (ms)
RPC_ROTATION_POLL_MS=250

# ── CONTRACTS ────────────────────────────────────────────────────────────────
# Standard self-funded executor
ARB_CONTRACT_ADDRESS=

# Aave flash-loan executor (TitanArbitrageExecutor.sol)
ARB_FLASH_EXECUTOR_ADDRESS=

# ── WALLET ───────────────────────────────────────────────────────────────────
PRIVATE_KEY=

# ── EXECUTION MODE ───────────────────────────────────────────────────────────
# Set false to go live
SAFE_MODE=true

# Set true to use Aave flash-loan path instead of self-funded
FLASH_LOAN_ENABLED=false

# Chains to scan (comma separated)
ACTIVE_CHAINS=arbitrum

# ── STRATEGY ─────────────────────────────────────────────────────────────────
TRADE_USD_HINT=250
MIN_GROSS_PROFIT_USD=1.5
MIN_NET_PROFIT_USD=1.0
SLIPPAGE_BPS=30

# ── GAS ──────────────────────────────────────────────────────────────────────
GAS_UNITS_APPROX=260000
MAX_GAS_TO_GROSS_RATIO=0.5

# ── TIMING ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=3000
ROUTE_DEADLINE_SECONDS=45

# ── PRICE ────────────────────────────────────────────────────────────────────
ETH_PRICE_USD_HINT=2200

# ── AAVE ─────────────────────────────────────────────────────────────────────
# Required when FLASH_LOAN_ENABLED=true
AAVE_POOL_ADDRESSES_PROVIDER=0xa97684ead0e402dC232d5A977953DF7ECBaB3CDb

