########################################
# ACTIVE CHAIN
########################################
ACTIVE_DEPLOY_CHAIN=polygon
ACTIVE_CHAINS=polygon

########################################
# WALLET
########################################
# MUST start with 0x
PRIVATE_KEY=

########################################
# CONTRACTS
########################################
POLYGON_FLASH_EXECUTOR_ADDRESS=
MATIC_FLASH_EXECUTOR_ADDRESS=
# Legacy fallback
ARB_FLASH_EXECUTOR_ADDRESS=

########################################
# AAVE V3 — Polygon PoS
########################################
