# ── RPC POOLS ────────────────────────────────────────────────────────────────
# Shared fallback pool (used when lane-specific vars are not set)
ARBITRUM_RPC_URLS=https://arb-premium-q1,https://arb-premium-q2,https://arb-premium-q3
ARBITRUM_WSS_URLS=wss://arb-wss-1,wss://arb-wss-2

# Single-URL fallback for makeProvider() (scanner/simulator legacy path)
ARBITRUM_RPC_URL=

# ── RPC LANES ────────────────────────────────────────────────────────────────
# Quote lane: fast reads for price discovery
ARBITRUM_QUOTE_RPC_URLS=https://arb-premium-q1,https://arb-premium-q2,https://arb-premium-q3
# Sim lane: eth_call simulations before execution
ARBITRUM_SIM_RPC_URLS=https://arb-premium-s1,https://arb-premium-s2
# Send lane: reserved for tx submit and receipt tracking only
ARBITRUM_SEND_RPC_URLS=https://arb-premium-tx1,https://arb-premium-tx2

# Requests per second for each provider (comma list, matches URL order)
ARBITRUM_QUOTE_RPC_RPS=6,4,3
ARBITRUM_SIM_RPC_RPS=2,2
ARBITRUM_SEND_RPC_RPS=1,1

# Token bucket burst sizes
RPC_BURST_QUOTE=6
RPC_BURST_SIM=3
RPC_BURST_SEND=2

# Per-lane RPC timeouts (ms)
RPC_TIMEOUT_MS_QUOTE=3000
RPC_TIMEOUT_MS_SIM=4500
RPC_TIMEOUT_MS_SEND=8000

# ── CONTRACTS ────────────────────────────────────────────────────────────────
# Standard self-funded executor (ArbitrageExecutor.sol)
ARB_CONTRACT_ADDRESS=

# Aave flash-loan executor (TitanArbitrageExecutor.sol)
ARB_FLASH_EXECUTOR_ADDRESS=

# ── WALLET ───────────────────────────────────────────────────────────────────
PRIVATE_KEY=

# ── EXECUTION MODE ───────────────────────────────────────────────────────────
SAFE_MODE=true
FLASH_LOAN_ENABLED=true
ACTIVE_CHAINS=arbitrum
ACTIVE_DEPLOY_CHAIN=arbitrum

# ── STRATEGY ─────────────────────────────────────────────────────────────────
TRADE_USD_HINT=250
MIN_GROSS_PROFIT_USD=1.5
MIN_NET_PROFIT_USD=1.0
SLIPPAGE_BPS=30

# ── GAS ──────────────────────────────────────────────────────────────────────
GAS_UNITS_APPROX=260000
MAX_GAS_TO_GROSS_RATIO=0.5

# ── TIMING ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=3000
ROUTE_DEADLINE_SECONDS=45

# ── PRICE ────────────────────────────────────────────────────────────────────
ETH_PRICE_USD_HINT=2200

# ── AAVE ─────────────────────────────────────────────────────────────────────
AAVE_POOL_ADDRESSES_PROVIDER=0xa97684ead0e402dC232d5A977953DF7ECBaB3CDb

# ── DRY RUN ──────────────────────────────────────────────────────────────────
DRY_RUN_USD=25
