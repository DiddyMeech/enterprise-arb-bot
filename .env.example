POLYGON_SIM_RPC_RPS=4,3,2
POLYGON_SEND_RPC_RPS=2,1

RPC_BURST_QUOTE=8
RPC_BURST_SIM=4
RPC_BURST_SEND=2

########################################
# TIMEOUTS
########################################
RPC_TIMEOUT_MS_QUOTE=2500
RPC_TIMEOUT_MS_SIM=4500
RPC_TIMEOUT_MS_SEND=8000

########################################
# ROTATION / HEALTH SYSTEM
########################################
MIN_HEALTHY_QUOTE=5
MIN_HEALTHY_SIM=3
MIN_HEALTHY_SEND=2
RPC_REFRESH_INTERVAL_MS=600000
RPC_QUARANTINE_AFTER_FAILURES=4
RPC_QUARANTINE_BASE_MS=600000
RPC_MAX_BLOCK_LAG=4

########################################
# ALERTING (OPTIONAL)
########################################
RPC_ALERT_WEBHOOK_URL=

